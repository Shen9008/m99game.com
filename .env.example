# Copy to `.env.local` (gitignored) for `npm run sync`.
# Run `npm run sync:doctor` to print a sample request URL from these values.

# Base URL including /api (no trailing slash required)
STRAPI_API_URL=http://165.22.62.92/api

# Optional: Bearer token if the API requires auth
STRAPI_API_TOKEN=

# Multi-tenant filter value (must match your CMS). Leave unset only if the API is single-site
# or set SKIP_POSTS_SITE_FILTER=1 to omit the filter query param entirely.
SITE_DOMAIN=m99game.com

# --- Optional overrides when reusing this repo on another Strapi project ---

# REST collection name (plural API ID), default: posts
# POSTS_COLLECTION=posts

# Strapi v4 filter key for SITE_DOMAIN. Default: filters[site][domain][$eq]
# Example other shape: filters[tenant][slug][$eq]
# POSTS_SITE_FILTER_KEY=filters[site][domain][$eq]

# Set to 1 to never send a domain filter (single-tenant CMS)
# SKIP_POSTS_SITE_FILTER=

# Leave POSTS_SITE_FILTER_KEY empty in .env to disable only the filter param while keeping SITE_DOMAIN for other use:
# POSTS_SITE_FILTER_KEY=
